  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "indexer": "tsx scripts/indexer.ts",
    "indexer:once": "tsx scripts/indexer.ts --once",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@opaquecash/deployments": "^0.2.2",
    "@opaquecash/privacy-pool": "^0.2.0",
    "@solana/web3.js": "^1.95.4",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
