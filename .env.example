# Which pools to service (comma-separated): evm, solana. Default: both.
ASP_CHAINS=evm,solana

# How often to run a tick when looping (ms). Default 60000.
ASP_INTERVAL_MS=60000

# Where to persist association-set state + published manifests. Default: ./data
# ASP_DATA_DIR=./data

# ── Ethereum Sepolia ─────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://rpc.sepolia.org
SEPOLIA_PRIVATE_KEY=0x...        # the pool's aspAuthority key (posts setAspRoot)
# EVM chain id (Sepolia = 11155111). Pool address resolved from @opaquecash/deployments.
ASP_EVM_CHAIN_ID=11155111
# First block to scan for Deposit events on a fresh run. Defaults to the deployment's
# uabFromBlock (a safe lower bound). Set to the pool's deploy block to scan less.
# ASP_EVM_FROM_BLOCK=11022332
# Confirmations to wait before a deposit is eligible for the set (reorg safety). Default 5.
ASP_EVM_CONFIRMATIONS=5
# Max block span per getLogs request (RPC range cap). Default 10000.
ASP_EVM_MAX_BLOCK_SPAN=10000

# ── Solana devnet ────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR=~/.config/solana/id.json   # the pool's asp_authority keypair
ASP_SOLANA_CLUSTER=devnet

# ── IPFS publishing (optional) ───────────────────────────────────────────────
# Kubo-compatible HTTP API to pin the approved-label list (e.g. http://127.0.0.1:5001).
# If unset, manifests are still written locally; the CID is simply absent. The set is
# self-authenticating against the on-chain root, so IPFS is an availability aid only.
# IPFS_API_URL=http://127.0.0.1:5001

# ── ENS pointer (optional, decentralized discovery) ──────────────────────────
# Publish the latest manifest CID as an ENS text record so withdrawers can discover the
# current set via @opaquecash/privacy-pool resolveAspSetViaEns. Reuses the Sepolia RPC+key;
# the key must control ASP_ENS_NAME on the resolver. One name tracks one pool's manifest.
# Requires IPFS (a CID) to be present. Leave ASP_ENS_NAME unset to disable.
# ASP_ENS_NAME=evm-asp.opqtest.eth
# ASP_ENS_RESOLVER=0x...                     # ENS resolver holding the text record
# ASP_ENS_TEXT_KEY=com.opaque.aspset         # default; keep in sync with the client
# ASP_ENS_POOL_ID=evm:11155111               # which pool this name tracks (default EVM)
